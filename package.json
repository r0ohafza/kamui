{
  "name": "@rooh/kamui",
  "version": "0.1.0",
  "description": "Switch your main branch to any git worktree's state",
  "type": "module",
  "license": "MIT",
  "author": "r0ohafza",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/r0ohafza/kamui.git"
  },
  "homepage": "https://github.com/r0ohafza/kamui#readme",
  "bugs": {
    "url": "https://github.com/r0ohafza/kamui/issues"
  },
  "keywords": [
    "git",
    "worktree",
    "branch",
    "preview",
    "sync",
    "cli"
  ],
  "bin": {
    "kamui": "./dist/index.js"
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js",
    "lint": "eslint src/",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "prepublishOnly": "pnpm run build"
  },
  "dependencies": {
    "@inquirer/prompts": "^7.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "eslint": "^10.0.2",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.8.1",
    "tsup": "^8.5.1",
    "tsx": "^4.0.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.56.1"
  }
}
